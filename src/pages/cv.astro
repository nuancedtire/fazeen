---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout
	title="CV"
	description="CV of Dr Fazeen Nasser — ST3+ Emergency Medicine clinician at Barts Health NHS Trust, founding engineer of Peerr.io and Aiigent.io, and clinical AI builder."
>
	<div class="max-w-[720px] mx-auto px-6 py-24 md:py-32">

		<!-- Header -->
		<div class="mb-12">
			<div class="flex items-start justify-between gap-6 flex-wrap">
				<div>
					<p class="section-label mb-2">Curriculum Vitae</p>
					<h1 class="text-[2rem] font-semibold tracking-tight text-fg mb-2">Dr Fazeen Nasser</h1>
					<p class="text-[1.0625rem] text-fg-muted">
						Emergency Medicine Clinician · Clinical AI & Healthcare Technology
					</p>
					<p class="meta text-fg-subtle mt-2">
						GMC 7741002 · London, E11 · me@fazeen.dev
					</p>
					<p class="meta text-fg-subtle mt-1">
						linkedin.com/in/fazeen-nasser · github.com/nuancedtire · aide.fazeen.dev
					</p>
				</div>
				<a
					href="/Dr_Fazeen_Nasser_CV.pdf"
					target="_blank"
					class="inline-flex items-center gap-2 px-4 py-2 border border-rule text-fg-muted text-sm rounded-sm hover:text-fg hover:border-fg-subtle transition-colors shrink-0"
				>
					<svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
						<path d="M6.5 1v7M3.5 5.5l3 3 3-3M1.5 10.5h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
					Download PDF
				</a>
			</div>
		</div>

		<!-- Professional Profile -->
		<section class="cv-section" style="border-top: none; margin-top: 0; padding-top: 0;">
			<h2 class="cv-section-label">Professional Profile</h2>
			<p class="text-[0.9375rem] text-fg-muted leading-[1.8]">
				ST3+ Trust-grade Emergency Medicine clinician at Barts Health NHS Trust with an unusual parallel skillset in clinical AI and healthcare product delivery. Alongside full-time NHS practice, has independently designed and deployed an AI-powered clinical guidelines retrieval platform for Emergency Departments (<em>aide.fazeen.dev</em>), serves as Founding Engineer at the clinical AI ventures <em>Peerr.io</em> and <em>Aiigent.io</em>, and previously scaled a medical education platform to 500,000+ users. Active QI co-lead and teacher of medical students and FY2 doctors. Particular interest in the <strong class="text-fg">implementation science of clinical AI</strong> — moving working prototypes through NHS clinical safety, information governance and real-world evaluation into trusted, scalable products.
			</p>
		</section>

		<!-- Current Clinical Post -->
		<section class="cv-section">
			<h2 class="cv-section-label">Current Clinical Post</h2>
			<div class="cv-entry" style="margin-top: 0;">
				<p class="cv-role">Emergency Medicine Clinician (ST3+ Trust Grade)</p>
				<p class="cv-org">Whipps Cross Hospital, Barts Health NHS Trust · Dec 2023 – present</p>
				<ul class="cv-list">
					<li>Delivery of acute and resuscitation-level emergency care in one of London's busiest adult A&E departments, across resus, majors and ambulatory care.</li>
					<li>Independent senior trust-grade decision-making; supervising and supporting foundation and core-trainee colleagues on shift.</li>
					<li>Co-lead for an ongoing departmental QIP on mental health pathway compliance; regular teaching of medical students and FY2 doctors.</li>
				</ul>
			</div>
		</section>

		<!-- QI & Clinical Governance -->
		<section class="cv-section">
			<h2 class="cv-section-label">Quality Improvement & Clinical Governance</h2>
			<div class="cv-entry" style="margin-top: 0;">
				<p class="cv-role">QIP Co-Lead — Mental Health Pathway Compliance in the Emergency Department</p>
				<p class="cv-org">Whipps Cross A&E · 2024 – present</p>
				<ul class="cv-list">
					<li>Co-leading an ongoing quality improvement project with a departmental colleague, aligned with <strong class="text-fg">Royal College of Emergency Medicine</strong> standards for the assessment and management of mental health presentations in the ED.</li>
					<li>Identified that manual audit data collection was a key limiter of compliance visibility; designed and deployed a <strong class="text-fg">custom browser-based data-collection tool</strong> (developed with AI-assisted coding) to streamline capture for frontline staff.</li>
					<li>Built a dedicated project microsite (<em>qip.fazeen.dev</em>) for documentation and dissemination; currently in data-collection phase, with departmental presentation and re-audit cycle planned on completion.</li>
				</ul>
			</div>
		</section>

		<!-- Teaching -->
		<section class="cv-section">
			<h2 class="cv-section-label">Teaching</h2>
			<div class="cv-entry" style="margin-top: 0;">
				<ul class="cv-list">
					<li><strong class="text-fg">Medical Students</strong> — regular bedside and shift-based teaching of Barts and The London School of Medicine & Dentistry students on A&E placements; clinical reasoning, procedural skills, emergency presentations.</li>
					<li><strong class="text-fg">Foundation Year 2 Doctors</strong> — clinical supervision and procedural sign-off during A&E rotations; informal mentorship on QI methodology, documentation and management of the undifferentiated patient.</li>
				</ul>
			</div>
		</section>

		<!-- Previous Clinical Experience -->
		<section class="cv-section">
			<h2 class="cv-section-label">Previous Clinical Experience</h2>
			<div class="cv-entry" style="margin-top: 0;">
				<p class="cv-role">Family Physician</p>
				<p class="cv-org">City Dental Clinic & Diagnostic Centre, Kerala, India · Jul 2022 – Apr 2023</p>
				<ul class="cv-list">
					<li>Independent primary care in a resource-limited setting; led implementation of a full Electronic Health Record system in a previously paper-based practice, achieving 100% staff adoption.</li>
				</ul>
			</div>
			<div class="cv-entry">
				<p class="cv-role">Medical Doctor (Internship)</p>
				<p class="cv-org">Kasturba Medical College, Manipal, India · Mar 2018 – Sep 2019</p>
				<ul class="cv-list">
					<li>Statutory rotations across medicine, surgery, paediatrics, O&G and primary care. Case report on Fahr's disease subsequently presented at a medical conference, Newcastle (2021).</li>
				</ul>
			</div>
		</section>

		<!-- Clinical AI & Healthcare Technology -->
		<section class="cv-section">
			<h2 class="cv-section-label">Clinical AI & Healthcare Technology</h2>
			<p class="text-[0.8125rem] text-fg-subtle italic mb-5 leading-relaxed">
				A portfolio bridging frontline clinical practice with independent delivery of production AI and digital-health systems. Where technical stack is listed, code was written by the applicant.
			</p>

			<div class="cv-entry" style="margin-top: 0;">
				<p class="cv-role">Aide — AI-Assisted Clinical Guideline Retrieval Platform for EDs</p>
				<p class="cv-org">Independent project · aide.fazeen.dev · 2025 – present</p>
				<ul class="cv-list">
					<li>Clinician-built <strong class="text-fg">retrieval-augmented generation (RAG)</strong> platform enabling ED staff to query local guidelines, pathways, contact numbers and equipment locations in plain English, with source-cited responses. Retrieves and presents information only — does not triage, diagnose, or recommend treatment.</li>
					<li>Stack: React 19, Convex real-time database, LLM-based agent with automated PDF/DOCX ingestion, confidence scoring, clinician feedback capture, usage analytics and audit trail. Administrator-driven content updates without IT involvement.</li>
					<li>Reviewed by proposed fellowship supervisor; undergoing enhancement ahead of the proposed <strong class="text-fg">InnovateMD 2026 NHS deployment, clinical safety case and mixed-methods evaluation</strong>.</li>
				</ul>
			</div>

			<div class="cv-entry">
				<p class="cv-role">Founding Engineer — Peerr.io / Aiigent.io</p>
				<p class="cv-org">AI-powered clinical networking & workflow tooling · 2023 – present</p>
				<ul class="cv-list">
					<li>Founding engineer on Peerr.io, a secure regulated professional network for health and life sciences; <strong class="text-fg">15,000+ registered users, ~3,000 MAU</strong>. Shipped LLM-powered features (news summarisation, job screening, content curation) using structured outputs and prompt engineering tuned for clinical accuracy.</li>
					<li>Co-building the sister platform Aiigent.io on a common technical foundation, hosting clinical workflow tools including <strong class="text-fg">Compass</strong> (<em>compass.aiigent.io</em>) and <strong class="text-fg">NEA</strong> (<em>nea.aiigent.io</em>).</li>
					<li>Responsible for SOC 2 and GDPR compliance posture across the platform: data handling, consent and content moderation appropriate to a clinical user base.</li>
				</ul>
			</div>

			<div class="cv-entry">
				<p class="cv-role">Consultant, Medical Operations & Product</p>
				<p class="cv-org">DailyRounds / Marrow, Bengaluru, India · Dec 2019 – Jun 2022</p>
				<ul class="cv-list">
					<li>Scaled India's leading medical education platform for NEET-PG exam preparation to <strong class="text-fg">500,000+ users</strong>; led a cross-functional team of 20+ medical editors across four specialty teams with structured review and QA processes.</li>
					<li>Designed and launched the flagship "Pearls" feature (indexed, searchable clinical content); acted as primary clinical liaison between engineering and physician users, translating workflow into product requirements.</li>
				</ul>
			</div>

			<div class="cv-entry">
				<p class="cv-role">Independent Healthcare AI Portfolio</p>
				<p class="cv-org">Sole developer · 2018 – present</p>
				<ul class="cv-list">
					<li><strong class="text-fg">NeurallyMed</strong> (2022–23) — AI-powered PLAB exam preparation platform; acquired 2023. <strong class="text-fg">AskNICE</strong> (2023) — RAG conversational interface over NICE clinical guidelines. <strong class="text-fg">Leanifi</strong> (<em>leanifi.fazeen.dev</em>) — AI-powered fitness and nutrition assistant.</li>
					<li><strong class="text-fg">CXR Triage System</strong> (2018) — convolutional neural network (PyTorch) for chest X-ray prioritisation. <strong class="text-fg">ET Tube Placement Detector</strong> (2019) — deep-learning tool for neonatal intubation verification. <strong class="text-fg">MIT COVID-19 Hackathon</strong> (2020) — team 2nd place in clinical AI triage track.</li>
				</ul>
			</div>
		</section>

		<!-- Qualifications -->
		<section class="cv-section">
			<h2 class="cv-section-label">Qualifications, Certifications & Skills</h2>
			<div class="cv-skills" style="margin-top: 0;">
				<p>
					<strong class="text-fg">Medical:</strong> MBBS, Kasturba Medical College, Manipal (2019). GMC: 7741002, Full Registration with Licence to Practise. Clinical courses: Advanced Life Support (ALS, RC UK); Point-of-Care Ultrasound (POCUS).
				</p>
				<p>
					<strong class="text-fg">Technical:</strong> Python, TypeScript, React; LLMs, prompt engineering, RAG; EHR implementation and clinical decision support design; SOC 2 and GDPR compliance for healthcare software.
				</p>
				<p>
					<strong class="text-fg">Product & leadership:</strong> user research, cross-functional team leadership, clinical-to-technical translation, agile delivery.
				</p>
			</div>
		</section>

		<!-- Achievements -->
		<section class="cv-section">
			<h2 class="cv-section-label">Selected Achievements & Publications</h2>
			<div class="cv-entry" style="margin-top: 0;">
				<ul class="cv-list">
					<li><strong class="text-fg">Acquisition of NeurallyMed (2023)</strong> — independently built AI-powered PLAB exam preparation platform successfully acquired.</li>
					<li><strong class="text-fg">Fahr's disease — a case report.</strong> Presentation, medical conference, Newcastle (2021).</li>
				</ul>
			</div>
		</section>

	</div>
</BaseLayout>
