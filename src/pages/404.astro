---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="Page not found">
	<div class="max-w-[760px] mx-auto px-6 py-32 text-center">
		<h1 class="font-serif text-4xl text-fg mb-4 italic">Gone to another department.</h1>
		<p class="text-fg-muted mb-8">
			The page you're looking for isn't here.
		</p>
		<div class="flex flex-wrap justify-center gap-4">
			<a href="/work" class="meta text-accent hover:text-fg transition-colors">Work</a>
			<span class="meta text-fg-subtle">·</span>
			<a href="/writing" class="meta text-accent hover:text-fg transition-colors">Writing</a>
			<span class="meta text-fg-subtle">·</span>
			<a href="/" class="meta text-accent hover:text-fg transition-colors">Home</a>
		</div>
	</div>
</BaseLayout>
