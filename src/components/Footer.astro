---
import ThemeToggle from "./ThemeToggle.astro";

const year = new Date().getFullYear();

const navLinks = [
	{ href: "/work", label: "Work" },
	{ href: "/writing", label: "Writing" },
	{ href: "/now", label: "Now" },
	{ href: "/cv", label: "CV" },
	{ href: "/contact", label: "Contact" },
];
---

<footer class="border-t border-rule mt-24">
	<div
		class="max-w-[1100px] mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8"
	>
		<!-- Left: name + tagline + copyright + theme toggle -->
		<div class="flex flex-col gap-3">
			<a href="/" class="text-fg font-medium hover:text-accent transition-colors">
				Fazeen Nasser
			</a>
			<p class="text-sm text-fg-muted leading-relaxed">
				Emergency medicine clinician. Clinical AI builder.
			</p>
			<p class="meta text-fg-subtle">© {year} Dr Fazeen Nasser</p>
			<div class="mt-1">
				<ThemeToggle />
			</div>
		</div>

		<!-- Middle: nav links -->
		<nav aria-label="Footer" class="flex flex-col gap-2">
			{
				navLinks.map(({ href, label }) => (
					<a
						href={href}
						class="text-sm text-fg-muted hover:text-fg transition-colors"
					>
						{label}
					</a>
				))
			}
		</nav>

		<!-- Right: socials + colophon -->
		<div class="flex flex-col gap-3">
			<a
				href="mailto:me@fazeen.dev"
				class="text-sm text-fg-muted hover:text-fg transition-colors"
			>
				me@fazeen.dev
			</a>
			<a
				href="https://linkedin.com/in/fazeen-nasser"
				target="_blank"
				rel="noopener noreferrer"
				class="text-sm text-fg-muted hover:text-fg transition-colors"
			>
				LinkedIn
			</a>
			<a
				href="https://github.com/nuancedtire"
				target="_blank"
				rel="noopener noreferrer"
				class="text-sm text-fg-muted hover:text-fg transition-colors"
			>
				GitHub
			</a>
			<a
				href="/Dr_Fazeen_Nasser_CV.pdf"
				target="_blank"
				class="text-sm text-fg-muted hover:text-fg transition-colors"
			>
				CV (PDF)
			</a>
			<p class="meta text-fg-subtle mt-2">
				Built with <a
					href="https://astro.build"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-fg-muted transition-colors">Astro</a
				>
			</p>
		</div>
	</div>
</footer>
