---
import type { CollectionEntry } from "astro:content";

interface Props {
	entry: CollectionEntry<"work">;
	index?: number;
	showIndex?: boolean;
}

const { entry, index, showIndex = false } = Astro.props;
const { title, tagline, role, period, status } = entry.data;

const statusClass =
	status.toLowerCase().includes("live") || status.toLowerCase().includes("active")
		? "pill--live"
		: status.toLowerCase().includes("acquired") || status.toLowerCase().includes("place")
			? "pill--warm"
			: "";

const indexStr = index != null ? String(index).padStart(2, "0") : null;
---

<article class="group border-t border-rule">
	<a
		href={`/work/${entry.id}`}
		class="flex gap-6 py-7 hover:opacity-100"
		transition:name={`project-link-${entry.id}`}
	>
		<!-- Index number (work index only) -->
		{
			showIndex && indexStr && (
				<span class="meta text-fg-subtle/30 shrink-0 w-6 pt-0.5 hidden md:block select-none">
					{indexStr}
				</span>
			)
		}

		<!-- Content -->
		<div class="flex-1 min-w-0">
			<div class="flex items-start justify-between gap-4 mb-1.5">
				<h3
					class="text-[1.0625rem] font-medium text-fg group-hover:text-accent transition-colors leading-snug"
					transition:name={`project-title-${entry.id}`}
				>
					{title}
				</h3>
				<span class="meta text-fg-subtle shrink-0 hidden sm:block pt-0.5">{period}</span>
			</div>

			<p class="text-sm text-fg-muted leading-relaxed mb-3">{tagline}</p>

			<div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5">
				<span class="meta text-fg-subtle">{role}</span>
				<span class="meta text-fg-subtle/30">·</span>
				<span class={`pill ${statusClass}`}>{status}</span>
			</div>
		</div>
	</a>
</article>
