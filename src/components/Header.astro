---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
	{ href: "/work", label: "Work" },
	{ href: "/now", label: "Now" },
	{ href: "/cv", label: "CV" },
	{ href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
---

<header
	class="sticky top-0 z-50 border-b border-rule"
	style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); backdrop-filter: blur(12px);"
>
	<div class="max-w-[1100px] mx-auto px-6 h-14 flex items-center justify-between">
		<a
			href="/"
			class="font-mono text-sm text-fg-muted hover:text-fg transition-colors"
			aria-label="Fazeen Nasser — Home"
		>
			fazeen.dev
		</a>

		<!-- Desktop nav -->
		<nav aria-label="Primary" class="hidden md:flex items-center gap-1">
			{
				navLinks.map(({ href, label }) => {
					const isActive =
						href === "/"
							? pathname === "/"
							: pathname.startsWith(href);
					return (
						<a
							href={href}
							class={`px-3 py-1.5 text-sm rounded transition-colors ${
								isActive
									? "text-fg"
									: "text-fg-muted hover:text-fg"
							}`}
							aria-current={isActive ? "page" : undefined}
						>
							{label}
						</a>
					);
				})
			}
		</nav>

		<div class="flex items-center gap-3">
			<ThemeToggle />

			<!-- Mobile hamburger -->
			<button
				id="mobile-menu-toggle"
				class="md:hidden p-2 text-fg-muted hover:text-fg transition-colors"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg
					id="icon-menu"
					width="20"
					height="20"
					viewBox="0 0 20 20"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M3 5h14M3 10h14M3 15h14"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"></path>
				</svg>
				<svg
					id="icon-close"
					width="20"
					height="20"
					viewBox="0 0 20 20"
					fill="none"
					aria-hidden="true"
					class="hidden"
				>
					<path
						d="M5 5l10 10M15 5L5 15"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="hidden md:hidden border-t border-rule"
		role="dialog"
		aria-label="Navigation menu"
	>
		<nav class="flex flex-col px-6 py-4 gap-1">
			{
				navLinks.map(({ href, label }) => {
					const isActive =
						href === "/"
							? pathname === "/"
							: pathname.startsWith(href);
					return (
						<a
							href={href}
							class={`px-3 py-2.5 text-sm rounded transition-colors ${
								isActive
									? "text-fg bg-bg-elev"
									: "text-fg-muted hover:text-fg hover:bg-bg-elev"
							}`}
							aria-current={isActive ? "page" : undefined}
						>
							{label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById("mobile-menu-toggle");
	const menu = document.getElementById("mobile-menu");
	const iconMenu = document.getElementById("icon-menu");
	const iconClose = document.getElementById("icon-close");

	toggle?.addEventListener("click", () => {
		const isOpen = !menu?.classList.contains("hidden");
		menu?.classList.toggle("hidden");
		iconMenu?.classList.toggle("hidden", !isOpen ? true : false);
		iconClose?.classList.toggle("hidden", !isOpen ? false : true);
		toggle.setAttribute("aria-expanded", String(!isOpen));
	});
</script>
