---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
	{ href: "/work", label: "Work" },
	{ href: "/now", label: "Now" },
	{ href: "/cv", label: "CV" },
	{ href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
---

<header
	class="sticky top-0 z-50 border-b border-rule"
	style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); backdrop-filter: blur(12px);"
>
	<div class="max-w-[1100px] mx-auto px-6 h-14 flex items-center justify-between">
		<a
			href="/"
			class="font-mono text-sm text-fg-muted hover:text-fg transition-colors"
			aria-label="Fazeen Nasser — Home"
		>
			fazeen.dev
		</a>

		<!-- Desktop nav -->
		<nav aria-label="Primary" class="hidden md:flex items-center gap-0.5">
			{
				navLinks.map(({ href, label }) => {
					const isActive =
						href === "/"
							? pathname === "/"
							: pathname.startsWith(href);
					return (
						<a
							href={href}
							class={`nav-link ${isActive ? "nav-link--active" : ""}`}
							aria-current={isActive ? "page" : undefined}
						>
							{label}
						</a>
					);
				})
			}
		</nav>

		<div class="flex items-center gap-3">
			<ThemeToggle />

			<!-- Mobile hamburger -->
			<button
				id="mobile-menu-toggle"
				class="md:hidden p-2 text-fg-muted hover:text-fg transition-colors"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg
					id="icon-menu"
					width="20"
					height="20"
					viewBox="0 0 20 20"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M3 5h14M3 10h14M3 15h14"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"></path>
				</svg>
				<svg
					id="icon-close"
					width="20"
					height="20"
					viewBox="0 0 20 20"
					fill="none"
					aria-hidden="true"
					class="hidden"
				>
					<path
						d="M5 5l10 10M15 5L5 15"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="hidden md:hidden border-t border-rule overflow-hidden"
		role="dialog"
		aria-label="Navigation menu"
	>
		<nav id="mobile-nav" class="flex flex-col px-6 py-4 gap-1">
			{
				navLinks.map(({ href, label }) => {
					const isActive =
						href === "/"
							? pathname === "/"
							: pathname.startsWith(href);
					return (
						<a
							href={href}
							class={`mobile-nav-link px-3 py-2.5 text-sm rounded ${
								isActive
									? "text-fg bg-bg-elev"
									: "text-fg-muted hover:text-fg hover:bg-bg-elev"
							}`}
							aria-current={isActive ? "page" : undefined}
						>
							{label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById("mobile-menu-toggle");
	const menu = document.getElementById("mobile-menu");
	const mobileNav = document.getElementById("mobile-nav");
	const iconMenu = document.getElementById("icon-menu");
	const iconClose = document.getElementById("icon-close");

	// Store the element that had focus before opening
	let lastFocusedElement: HTMLElement | null = null;

	function getFocusableElements(): HTMLElement[] {
		if (!menu) return [];
		return Array.from(
			menu.querySelectorAll(
				'a[href], button, textarea, input[type="text"], input[type="radio"], input[type="checkbox"], select'
			)
		).filter((el) => {
			const element = el as HTMLElement;
			return element.tabIndex >= 0 && !element.hasAttribute('disabled');
		}) as HTMLElement[];
	}

	function trapFocus(e: KeyboardEvent) {
		if (!menu || menu.classList.contains('hidden')) return;
		
		const focusableElements = getFocusableElements();
		if (focusableElements.length === 0) return;
		
		const firstElement = focusableElements[0];
		const lastElement = focusableElements[focusableElements.length - 1];
		
		if (e.key === 'Tab') {
			if (e.shiftKey && document.activeElement === firstElement) {
				e.preventDefault();
				lastElement.focus();
			} else if (!e.shiftKey && document.activeElement === lastElement) {
				e.preventDefault();
				firstElement.focus();
			}
		}
	}

	function handleEscape(e: KeyboardEvent) {
		if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
			closeMenu();
		}
	}

	function openMenu() {
		if (!menu || !toggle) return;
		lastFocusedElement = document.activeElement as HTMLElement;
		
		// Show menu with animation
		menu.classList.remove('hidden');
		menu.classList.add('mobile-menu-enter');
		menu.classList.remove('mobile-menu-exit');
		
		// Add class to parent for link stagger animation
		mobileNav?.classList.add('mobile-menu-open');
		
		iconMenu?.classList.add('hidden');
		iconClose?.classList.remove('hidden');
		toggle.setAttribute('aria-expanded', 'true');
		toggle.setAttribute('aria-label', 'Close navigation menu');
		
		// Focus first menu item after animation
		setTimeout(() => {
			const firstLink = menu.querySelector('a');
			firstLink?.focus();
		}, 100);
		
		document.addEventListener('keydown', trapFocus);
		document.addEventListener('keydown', handleEscape);
	}

	function closeMenu() {
		if (!menu || !toggle) return;
		
		// Animate out
		menu.classList.add('mobile-menu-exit');
		menu.classList.remove('mobile-menu-enter');
		mobileNav?.classList.remove('mobile-menu-open');
		
		// Hide after animation
		setTimeout(() => {
			menu.classList.add('hidden');
			menu.classList.remove('mobile-menu-exit');
		}, 200);
		
		iconMenu?.classList.remove('hidden');
		iconClose?.classList.add('hidden');
		toggle.setAttribute('aria-expanded', 'false');
		toggle.setAttribute('aria-label', 'Open navigation menu');
		
		document.removeEventListener('keydown', trapFocus);
		document.removeEventListener('keydown', handleEscape);
		
		// Return focus to toggle button
		lastFocusedElement?.focus();
	}

	toggle?.addEventListener('click', () => {
		const isOpen = !menu?.classList.contains('hidden');
		if (isOpen) {
			closeMenu();
		} else {
			openMenu();
		}
	});
</script>
