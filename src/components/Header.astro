---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/now", label: "Now" },
  { href: "/cv", label: "CV" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-rule"
  style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); backdrop-filter: blur(12px);"
>
  <div
    class="max-w-[1100px] mx-auto px-6 h-14 flex items-center justify-between"
  >
    <a
      href="/"
      class="font-mono text-sm text-fg-muted hover:text-fg transition-colors"
      aria-label="Fazeen Nasser — Home"
    >
      fazeen.dev
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden md:flex items-center gap-0.5">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/" ? pathname === "/" : pathname.startsWith(href);
          return (
            <a
              href={href}
              class={`nav-link ${isActive ? "nav-link--active" : ""}`}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-fg-muted hover:text-fg transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-menu"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M3 5h14M3 10h14M3 15h14"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        <svg
          id="icon-close"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
          class="hidden"
        >
          <path
            d="M5 5l10 10M15 5L5 15"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-rule"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    style="transition: opacity 200ms ease, transform 200ms ease; opacity: 0; transform: translateY(-4px);"
  >
    <nav class="flex flex-col px-6 py-4 gap-1">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/" ? pathname === "/" : pathname.startsWith(href);
          return (
            <a
              href={href}
              class={`px-3 py-2.5 text-sm rounded transition-colors ${
                isActive
                  ? "text-fg bg-bg-elev"
                  : "text-fg-muted hover:text-fg hover:bg-bg-elev"
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (!toggle || !menu) return;

    let lastFocusedElement: Element | null = null;

    function getFocusableElements(): HTMLElement[] {
      const focusable = menu.querySelectorAll<HTMLElement>(
        'a[href], button, input, textarea, select, details, [tabindex]:not([tabindex="-1"])',
      );
      return Array.from(focusable).filter(
        (el) => !el.hasAttribute("disabled") && !el.hasAttribute("hidden"),
      );
    }

    function trapFocus(e: KeyboardEvent) {
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.key === "Tab") {
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    function openMenu() {
      lastFocusedElement = document.activeElement;
      menu.classList.remove("hidden");
      // Force reflow for transition
      void menu.offsetHeight;
      menu.style.opacity = "1";
      menu.style.transform = "translateY(0)";
      iconMenu?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
      toggle.setAttribute("aria-label", "Close navigation menu");
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", handleKeydown);
      // Focus first link after transition
      setTimeout(() => {
        const focusable = getFocusableElements();
        focusable[0]?.focus();
      }, 50);
    }

    function closeMenu(returnFocus = true) {
      menu.style.opacity = "0";
      menu.style.transform = "translateY(-4px)";
      document.removeEventListener("keydown", handleKeydown);

      setTimeout(() => {
        menu.classList.add("hidden");
        iconMenu?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open navigation menu");
        document.body.style.overflow = "";
        if (returnFocus && lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
        }
      }, 200);
    }

    function handleKeydown(e: KeyboardEvent) {
      if (e.key === "Escape") {
        e.preventDefault();
        closeMenu();
      } else if (e.key === "Tab") {
        trapFocus(e);
      }
    }

    function onToggleClick() {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    // Reset menu state on navigation
    menu.classList.add("hidden");
    menu.style.opacity = "0";
    menu.style.transform = "translateY(-4px)";
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Open navigation menu");
    document.body.style.overflow = "";

    // Clean up old listener by cloning
    const freshToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.replaceWith(freshToggle);
    freshToggle.addEventListener("click", onToggleClick);
  }

  // Run on initial load and after each view transition
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
