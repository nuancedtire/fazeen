---
import "@fontsource-variable/inter";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from "../consts";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonicalURL?: string;
}

const {
	title,
	description = SITE_DESCRIPTION,
	ogImage = "/og-default.png",
	canonicalURL = Astro.url.href,
} = Astro.props;

const pageTitle = title
	? `${title} — Fazeen Nasser`
	: "Dr Fazeen Nasser — Emergency Medicine Clinician & Clinical AI Builder";
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<!--
			Runs once on initial page load to set the correct theme immediately (no FOUC).
			Also hooks astro:before-swap so the INCOMING document gets the right data-theme
			before it's rendered — this is what prevents the flash on navigation.
		-->
		<script is:inline>
			(function () {
				function resolveTheme() {
					const saved = localStorage.getItem("theme") || "system";
					if (saved === "system") {
						return window.matchMedia("(prefers-color-scheme: dark)").matches
							? "dark"
							: "light";
					}
					return saved;
				}

				// Apply on initial load
				document.documentElement.setAttribute("data-theme", resolveTheme());

				// Patch incoming document before the swap so there is never a flash
				document.addEventListener("astro:before-swap", function (e) {
					e.newDocument.documentElement.setAttribute("data-theme", resolveTheme());
				});
			})();
		</script>

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Dr Fazeen Nasser" />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, SITE_URL).toString()} />
		<meta property="og:site_name" content={SITE_TITLE} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(ogImage, SITE_URL).toString()} />

		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<ClientRouter />

		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Fazeen Nasser",
				"honorificPrefix": "Dr",
				"jobTitle": "Emergency Medicine Clinician",
				"affiliation": "Barts Health NHS Trust",
				"url": "https://fazeen.dev",
				"sameAs": [
					"https://linkedin.com/in/fazeen-nasser",
					"https://github.com/nuancedtire"
				]
			}
		</script>
	</head>
	<body class="bg-bg text-fg">
		<!-- Ambient background effects -->
		<div class="ambient-orb" aria-hidden="true"></div>
		<div class="ambient-orb-warm" aria-hidden="true"></div>
		<div class="grain-overlay" aria-hidden="true"></div>
		
		<a href="#main-content" class="skip-to-content">Skip to content</a>
		<Header />
		<main id="main-content">
			<slot />
		</main>
		<Footer />
		
		<!-- Load animations script -->
		<script src="../scripts/animations.ts"></script>
	</body>
</html>
